# ZenBox Mail — example environment file.
#
# ZenBox does NOT read secrets from .env at runtime. All credentials are
# entered inside the app (Settings) and stored in the OS keychain
# (Windows Credential Manager). This file only documents what you need.
#
# 1) Gmail OAuth client (Desktop app type) — created in Google Cloud Console.
#    Entered in: Settings -> Account. See docs/SETUP.md.
GMAIL_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-client-secret

# 2) AI provider keys (any one is enough). Entered in: Settings -> AI Providers.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
NVIDIA_NIM_API_KEY=nvapi-...
# Optional: self-hosted NIM endpoint (default is https://integrate.api.nvidia.com/v1)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
