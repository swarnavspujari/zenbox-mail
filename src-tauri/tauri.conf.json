{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZenBox Mail",
  "version": "0.6.0",
  "identifier": "com.zenbox.mail",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZenBox Mail",
        "width": 1280,
        "height": 840,
        "minWidth": 940,
        "minHeight": 600,
        "backgroundColor": "#0e1014"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https: http:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/32x32.png", "icons/128x128.png"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNUQ0QTUxNkQ5MTE2NTgKUldSWUZwRnRVVXBka2s0RnBuSUMvTko3Uk1DYmJtNUNLc0VuUVl6bVlENm9tamlHdmhyQXY3K2MK",
      "endpoints": [
        "https://github.com/swarnavspujari/zenbox-mail/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
